# ============================================================
# Financial AI Pipeline — Environment Configuration
# ============================================================

# --- LLM Provider (DeepSeek) ---
# Uses OpenAI-compatible SDK. Works with DeepSeek official API
# or any OpenAI-compatible local proxy (Ollama, vLLM, etc.)
DEEPSEEK_API_KEY= your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Storage ---
SQLITE_DB_PATH=data/pipeline.db

# --- Pipeline ---
MAX_RETRIES=3
LOG_LEVEL=INFO
